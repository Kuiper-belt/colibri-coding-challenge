      "wind_direction": "INTEGER",
      "power_output": "DOUBLE",
      "metadata_datetime_created": "TIMESTAMP NOT NULL"
    },
    "gold": {
      "turbine_id": "INTEGER",
      "date": "DATE",
      "mean_power_output": "DOUBLE",
      "min_power_output": "DOUBLE",
