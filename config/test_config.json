    "silver_layer_config": {
      "format": "jdbc",
      "mode": "append",
      "table": "test_silver_table"
    },
    "quarantine_layer_config": {
      "format": "jdbc",
      "mode": "append",
      "table": "test_quarantine_table"
    },
    "gold_layer_config": {
      "format": "jdbc",
      "mode": "append",
      "table": "test_gold_table"
